<Window x:Class="CandleStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин ароматических свечей" 
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="🕯️ Магазин ароматических свечей 🕯️"
                   FontSize="22" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,15"/>
        
        <!-- Каталог -->
        <Border Grid.Row="1" Grid.Column="0" 
                BorderBrush="LightGray" BorderThickness="1" 
                CornerRadius="8" Padding="5" Margin="5">
            <StackPanel>
                <TextBlock Text="📋 Каталог свечей" 
                           FontSize="14" FontWeight="Bold" 
                           Margin="5,5,5,10"/>
                <ListBox x:Name="ProductsList" 
                         Height="360"
                         SelectionChanged="ProductsList_SelectionChanged"
                         DisplayMemberPath="Name"
                         FontSize="13"/>
            </StackPanel>
        </Border>
        
        <!-- Правая панель: детали и корзина -->
        <Border Grid.Row="1" Grid.Column="1" 
                BorderBrush="LightGray" BorderThickness="1" 
                CornerRadius="8" Padding="10" Margin="5">
            <StackPanel>
                <TextBlock Text="✨ Детали товара ✨" 
                           FontSize="14" FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                
                <Grid Margin="0,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Название:" FontWeight="Bold" Grid.Row="0" Grid.Column="0"/>
                    <TextBox x:Name="TxtName" IsReadOnly="True" Grid.Row="0" Grid.Column="1" Margin="5,0,0,0" Height="26"/>
                    
                    <TextBlock Text="Аромат:" FontWeight="Bold" Grid.Row="1" Grid.Column="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="TxtScent" IsReadOnly="True" Grid.Row="1" Grid.Column="1" Margin="5,8,0,0" Height="26"/>
                    
                    <TextBlock Text="Цена:" FontWeight="Bold" Grid.Row="2" Grid.Column="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="TxtPrice" IsReadOnly="True" Grid.Row="2" Grid.Column="1" Margin="5,8,0,0" Height="26"/>
                    
                    <TextBlock Text="На складе:" FontWeight="Bold" Grid.Row="3" Grid.Column="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="TxtStock" IsReadOnly="True" Grid.Row="3" Grid.Column="1" Margin="5,8,0,0" Height="26"/>
                    
                    <TextBlock Text="Кол-во:" FontWeight="Bold" Grid.Row="4" Grid.Column="0" Margin="0,12,0,0"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="5,12,0,0">
                        <Button x:Name="BtnMinus" Content="-" Width="35" Height="30" FontSize="14" FontWeight="Bold" Click="Minus_Click"/>
                        <TextBox x:Name="TxtQuantity" Text="1" Width="50" Height="30" TextAlignment="Center" Margin="5,0"/>
                        <Button x:Name="BtnPlus" Content="+" Width="35" Height="30" FontSize="14" FontWeight="Bold" Click="Plus_Click"/>
                    </StackPanel>
                </Grid>
                
                <Button x:Name="BtnAddToCart" 
                        Content="🛒 Добавить в корзину" 
                        Background="LightBlue" 
                        FontSize="13" FontWeight="Bold"
                        Height="35" Margin="0,15,0,10"
                        Click="AddToCart_Click"/>
                
                <Separator Margin="0,10"/>
                
                <TextBlock Text="🛍️ Корзина" 
                           FontSize="14" FontWeight="Bold" 
                           Margin="0,5,0,8"/>
                
                <ListBox x:Name="CartList" Height="110" Margin="0,0,0,8"/>
                
                <!-- ПРОСТАЯ ИТОГОВАЯ ЦЕНА - БЕЗ ЗАМОРОЧЕК -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,10">
                    <TextBlock Text="Итого:" FontWeight="Bold" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtTotal" Text="0 руб." FontSize="14" FontWeight="Bold" Foreground="DarkRed"/>
                </StackPanel>
                
                <Button x:Name="BtnCheckout" 
                        Content="✅ Оформить заказ" 
                        Background="LightGreen" 
                        FontSize="13" FontWeight="Bold"
                        Height="35"
                        Click="Checkout_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Статус-бар -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="Готов к работе"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
